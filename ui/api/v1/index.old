if (preg_match('~^/ftp/(\d+)$~', $path, $m) && $method === 'DELETE') {
  api_require_auth($pdo, 'ftp');
  $id = (int)$m[1];
  $jid = job_enqueue($pdo, 'ftp_delete', $id, ['action'=>'delete']);
