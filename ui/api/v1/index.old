//
// WireGuard (wg_peers + job wg_apply)
//
if ($path === '/wg/peers' && $method === 'POST') {
  api_require_auth($pdo, 'wireguard');
  $b = api_body_json();

  $name = trim((string)($b['name'] ?? 'peer'));
  $ip   = trim((string)($b['ip'] ?? ''));
  $pub  = trim((string)($b['public_key'] ?? ''));
  $psk  = trim((string)($b['preshared_key'] ?? ''));
  $allowed = trim((string)($b['allowed_ips'] ?? ''));
  $active  = array_key_exists('is_active',$b) ? (!empty($b['is_active']) ? 1 : 0) : 1;

  if ($ip === '' || $pub === '') api_json(400, ['ok'=>false,'error'=>'missing_ip_or_public_key']);

  // idempotent: public_key
  $st = $pdo->prepare("SELECT * FROM wg_peers WHERE public_key=? LIMIT 1");
  $st->execute([$pub]);
  $ex = $st->fetch();

  if ($ex) {
    $id = (int)$ex['id'];
    $pdo->prepare("UPDATE wg_peers SET name=?, ip=?, preshared_key=?, allowed_ips=?, is_active=? WHERE id=?")
        ->execute([$name, $ip, ($psk?:null), ($allowed?:null), $active, $id]);

    $jid = job_enqueue($pdo, 'wg_apply', 0, ['reason'=>'update_peer','peer_id'=>$id]);
    api_json(200, ['ok'=>true,'id'=>$id,'job_id'=>$jid,'mode'=>'updated']);
  }

  $pdo->prepare("INSERT INTO wg_peers(name, ip, public_key, preshared_key, allowed_ips, is_active)
                 VALUES(?,?,?,?,?,?)")
      ->execute([$name, $ip, $pub, ($psk?:null), ($allowed?:null), $active]);

  $id = (int)$pdo->lastInsertId();
  $jid = job_enqueue($pdo, 'wg_apply', 0, ['reason'=>'add_peer','peer_id'=>$id]);
  api_json(201, ['ok'=>true,'id'=>$id,'job_id'=>$jid,'mode'=>'created']);
}

if ($path === '/wg/peers' && $method === 'GET') {
  api_require_auth($pdo, 'wireguard');
  $items = $pdo->query("SELECT id,name,ip,public_key,allowed_ips,is_active,created_at
                        FROM wg_peers ORDER BY id DESC LIMIT 500")->fetchAll();
  api_json(200, ['ok'=>true,'items'=>$items]);
}

if (preg_match('~^/wg/peers/(\d+)$~', $path, $m) && $method === 'GET') {
  api_require_auth($pdo, 'wireguard');
  $id = (int)$m[1];
  $st=$pdo->prepare("SELECT * FROM wg_peers WHERE id=?");
  $st->execute([$id]);
  $p=$st->fetch();
  if(!$p) api_json(404, ['ok'=>false,'error'=>'not_found']);
  api_json(200, ['ok'=>true,'item'=>$p]);
}

if (preg_match('~^/wg/peers/(\d+)/toggle$~', $path, $m) && $method === 'POST') {
  api_require_auth($pdo, 'wireguard');
  $id = (int)$m[1];
  $b = api_body_json();

  $on = array_key_exists('is_active',$b) ? (!empty($b['is_active']) ? 1 : 0) : null;
  if ($on === null) api_json(400, ['ok'=>false,'error'=>'missing_is_active']);

  $pdo->prepare("UPDATE wg_peers SET is_active=? WHERE id=?")->execute([$on, $id]);
  $jid = job_enqueue($pdo, 'wg_apply', 0, ['reason'=>'toggle_peer','peer_id'=>$id]);
  api_json(200, ['ok'=>true,'id'=>$id,'job_id'=>$jid]);
}

if (preg_match('~^/wg/peers/(\d+)$~', $path, $m) && $method === 'DELETE') {
  api_require_auth($pdo, 'wireguard');
  $id = (int)$m[1];
  $pdo->prepare("DELETE FROM wg_peers WHERE id=?")->execute([$id]);
  $jid = job_enqueue($pdo, 'wg_apply', 0, ['reason'=>'delete_peer','peer_id'=>$id]);
  api_json(200, ['ok'=>true,'id'=>$id,'job_id'=>$jid]);
}

